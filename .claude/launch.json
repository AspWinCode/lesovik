{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "client-presentation",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "http.server", "7788", "--directory", "docs"],
      "port": 7788
    },
    {
      "name": "frontend-dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev", "--", "--port", "5173"],
      "port": 5173,
      "cwd": "frontend"
    },
    {
      "name": "frontend-mock",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:mock", "--", "--port", "5173"],
      "port": 5173,
      "cwd": "frontend"
    }
  ]
}
