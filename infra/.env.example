# ============================================================
# No-Code Platform — environment variables template
# cp infra/.env.example infra/.env  and fill in your values
# NEVER commit infra/.env to version control
# ============================================================

# --- App ---
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-please-use-openssl-rand-hex-32

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=nocode
POSTGRES_USER=app_user
POSTGRES_PASSWORD=app_pass
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# --- JWT (RS256) ---
# Generate with:
#   openssl genrsa -out private.pem 4096
#   openssl rsa -in private.pem -pubout -out public.pem
# Then set single-line PEM (replace newlines with \n):
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# --- MinIO (dev S3) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_FILES=nocode-files
S3_BUCKET_EXPORTS=nocode-exports

# --- SMTP (MailHog in dev) ---
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
EMAIL_FROM=noreply@nocode.local

# --- CORS ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Grafana ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# --- ClamAV ---
CLAMAV_HOST=clamav
CLAMAV_PORT=3310
